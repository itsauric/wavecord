{
	"name": "wavecord",
	"version": "1.0.0",
	"description": "A modern Discord.js radio client - search 500k+ stations from Radio Browser and stream them into voice channels",
	"type": "module",
	"main": "./dist/index.cjs",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"import": {
				"types": "./dist/index.d.ts",
				"default": "./dist/index.js"
			},
			"require": {
				"types": "./dist/index.d.cts",
				"default": "./dist/index.cjs"
			}
		}
	},
	"files": [
		"dist"
	],
	"scripts": {
		"build": "tsup",
		"dev": "tsup --watch",
		"typecheck": "tsc --noEmit"
	},
	"keywords": [
		"discord",
		"radio",
		"discord.js",
		"voice",
		"music",
		"stream",
		"radio-browser"
	],
	"author": "itsauric",
	"license": "MIT",
	"dependencies": {
		"prism-media": "^1.3.5",
		"radio-browser-api": "^6.0.3"
	},
	"peerDependencies": {
		"@discordjs/voice": ">=0.17.0",
		"discord.js": ">=14.0.0"
	},
	"devDependencies": {
		"@discordjs/voice": "^0.19.2",
		"discord.js": "^14.0.0",
		"tsup": "^8.0.0",
		"typescript": "^5.0.0"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/itsauric/wavecord.git"
	},
	"bugs": {
		"url": "https://github.com/itsauric/wavecord/issues"
	},
	"homepage": "https://github.com/itsauric/wavecord#readme"
}
